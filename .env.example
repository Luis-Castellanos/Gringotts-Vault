# Neon connection string. Get this from neon.tech after creating a project.
# For local development with Docker, this is fine:
# DATABASE_URL="postgresql://vault:vault@localhost:5432/vault"
DATABASE_URL=""

# Optional: a separate read-only or pooled connection string for production reads
# DATABASE_URL_POOLED=""

# Optional: Anthropic key for "Categorize with Claude" (also settable in Settings).
# ANTHROPIC_API_KEY=""

# Optional: Twelve Data key for live market quotes / index benchmarks on the
# Investments page (also settable in Settings → Market data).
# MARKET_DATA_KEY=""

# Optional: logo.dev publishable token for full-fidelity brand wordmark logos
# (falls back to Google favicons when unset). Publishable, so NEXT_PUBLIC_.
# NEXT_PUBLIC_LOGO_DEV_TOKEN=""

# ── Auth / hosting (passkey login) ──────────────────────────────────────────
# Required in production. Locally these default to localhost and a dev secret.
#
# SESSION_SECRET: 32+ random chars; signs session + WebAuthn-challenge JWTs.
#   Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# SESSION_SECRET=""
#
# RP_ID: the site's domain, NO scheme/port (must match the URL you visit).
#   dev: localhost   prod: vault.yourdomain.com
# RP_ID="localhost"
#
# APP_ORIGIN: expected origin(s), comma-separated, WITH scheme.
#   dev: http://localhost:3000   prod: https://vault.yourdomain.com
# APP_ORIGIN="http://localhost:3000"

# Uploads need the local Python parser, which can't run on Vercel. The app
# auto-detects Vercel and disables uploads there. Override if self-hosting with
# Python available ("1" forces on) or to force off ("0").
# PARSER_ENABLED=""
